generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Produto {
  id        String   @id @default(cuid())
  nome      String
  descricao String?
  preco     Float
  imagemUrl String?
  criadoEm  DateTime @default(now())
}
